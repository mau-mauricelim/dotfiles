get_rand_name() { echo "${ADJECTIVES[$(( RANDOM % ${#ADJECTIVES[@]} ))]}-${NAMES[$(( RANDOM % ${#NAMES[@]} ))]}"; }

# : as delimiter
last_detached=$(tmux list-sessions -f "#{==:#{session_attached},0}" -F "#{session_last_attached} #{session_name}" 2>/dev/null | sort -nr | head -n1 | cut -d' ' -f2)

if [[ -n "$last_detached" ]]; then
    if [[ -n "$TMUX" ]]; then
        echo 'sessions should be nested with care, unset $TMUX to force'
    else
        tmux attach-session -t "$last_detached"
    fi
    exit 0
fi

for i in {1..5}; do
    rand_name=$(get_rand_name)
    if ! tmux has-session -t="$rand_name" 2>/dev/null; then
        tmux new-session -s "$rand_name"
        break
    fi
done
