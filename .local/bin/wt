#!/usr/bin/env bash
# wt - Git Worktree CLI

# TODO: Add test file
# Change prune to nuke :)
# Can the init not be shared between bash and zsh?
# gzip wt.1 later?
# Sanitize branch names
# Update the usage with all the flags
# wt ignore
# local gitignore without staging

set -euo pipefail

# Colors (stderr only)
if [[ -t 2 ]]; then
  C_BLUE=$'\e[34m' C_GREEN=$'\e[32m' C_YELLOW=$'\e[33m' C_RED=$'\e[31m' C_RESET=$'\e[0m'
else
  C_BLUE= C_GREEN= C_YELLOW= C_RED= C_RESET=
fi

info()    { echo "${C_BLUE}→${C_RESET} $1" >&2; }
success() { echo "${C_GREEN}✓${C_RESET} $1" >&2; }
warn()    { echo "${C_YELLOW}⚠${C_RESET} $1" >&2; }
error()   { echo "${C_RED}✗${C_RESET} $1" >&2; }

# ───── INIT ─────
if [[ "${1:-}" == "init" ]]; then
  cat <<'SHELL_INIT'
wt() {
  local output
  output="$(command wt "$@")"
  if [[ -n "$output" && -d "$output" ]]; then
    echo -e "\033[34m→\033[0m $(basename "$output")" >&2
    cd "$output" || return 1
  else
    printf '%s\n' "$output"
  fi
}
SHELL_INIT
  exit 0
fi

GIT_COMMON_DIR=$(git rev-parse --git-common-dir 2>/dev/null) || { error "Not inside a Git repository"; exit 1; }
GIT_ROOT=$(cd "$(dirname "$GIT_COMMON_DIR")" && pwd -P)
WORKTREE_BASE="$GIT_ROOT/.worktree"
mkdir -p "$WORKTREE_BASE"

CURRENT_PATH=$(pwd -P)
if [[ "$CURRENT_PATH" == "$WORKTREE_BASE/"* ]]; then
  CURRENT_NAME="${CURRENT_PATH#"$WORKTREE_BASE"/}"
  IN_WORKTREE=1
else
  CURRENT_NAME=""
  IN_WORKTREE=0
fi

sanitize_name() {
  echo "$1" | tr '/' '-' | tr ' ' '_' | tr -cd 'A-Za-z0-9_.-'
}

CMD="${1:-}"
shift || true

FORCE=0
NEW_ARGS=()
for arg in "$@"; do
  if [[ "$arg" == "-f" || "$arg" == "--force" ]]; then
    FORCE=1
  else
    NEW_ARGS+=("$arg")
  fi
done
set -- "${NEW_ARGS[@]}"

case "$CMD" in
  ""|help|--help|-h)
    cat <<EOF >&2
wt — Git worktree manager

Usage: wt <command>

Commands:
  init                    Print shell wrapper (eval "\$(wt init)")
  add <name>              New branch + worktree
  co <name>               Switch to worktree
  rm [-f] [<name>]        Remove
  prune                   git worktree prune
  ls                      List
  mv <old> <new>          Move + rename
  ignore                  Auto-add .worktree/ to .gitignore + stage it
EOF
    exit 0
    ;;

  ignore)
    if [[ ! -f .gitignore ]]; then
      echo ".worktree/" > .gitignore
      info "Created .gitignore with .worktree/"
    elif ! grep -qE '^\.worktree/?$' .gitignore; then
      echo ".worktree/" >> .gitignore
      info "Appended .worktree/ to .gitignore"
    else
      success "Already ignored (.worktree/ is in .gitignore)"
      exit 0
    fi
    git add .gitignore
    success "Staged .gitignore — commit when ready: git commit -m 'ignore worktrees'"
    ;;

  add)
    [[ $# -eq 0 ]] && { error "Usage: wt add <name>"; exit 1; }
    user_name="$1"
    dir_name=$(sanitize_name "$user_name")
    path="$WORKTREE_BASE/$dir_name"

    [[ -d "$path" ]] && { error "Worktree '$dir_name' already exists"; exit 1; }
    git show-ref --verify --quiet "refs/heads/$user_name" && { error "Branch '$user_name' exists — use 'wt co'"; exit 1; }

    info "Creating branch '$user_name' → folder '$dir_name'"
    git worktree add -b "$user_name" "$path"
    echo "$path"          # ← ONLY this goes to stdout for auto-cd
    ;;

  co)
    [[ $# -eq 0 ]] && { error "Usage: wt co <name>"; exit 1; }
    user_name="$1"
    dir_name=$(sanitize_name "$user_name")
    path="$WORKTREE_BASE/$dir_name"

    # Try sanitized first, then original
    if [[ ! -d "$path" ]]; then
      path="$WORKTREE_BASE/$user_name"
    fi

    if [[ -d "$path" ]]; then
      info "Switching to '$dir_name'"
      echo "$path"
      exit 0
    fi

    # Create from branch
    if git show-ref --verify --quiet "refs/heads/$user_name"; then
      info "Adding worktree for local branch '$user_name'"
      git worktree add "$WORKTREE_BASE/$dir_name" "$user_name"
    elif git show-ref --verify --quiet "refs/remotes/origin/$user_name"; then
      info "Adding worktree for remote branch origin/$user_name"
      git worktree add -b "$user_name" "$WORKTREE_BASE/$dir_name" "origin/$user_name"
    else
      error "Branch '$user_name' not found"
      exit 1
    fi
    echo "$WORKTREE_BASE/$dir_name"
    ;;

  rm)
    name="${1:-}"
    [[ -z "$name" ]] && { [[ $IN_WORKTREE -eq 0 ]] && { error "Not in a worktree"; exit 1; }; name="$CURRENT_NAME"; }

    dir_name=$(sanitize_name "$name")
    path="$WORKTREE_BASE/$dir_name"
    [[ ! -d "$path" ]] && path="$WORKTREE_BASE/$name"   # fallback

    [[ ! -d "$path" ]] && { error "Worktree '$name' not found"; exit 1; }

    [[ "$CURRENT_PATH" == "$path"* ]] && echo "$GIT_ROOT"

    info "Removing '$dir_name'${FORCE:+ (forced)}"
    git worktree remove ${FORCE:+-f} "$path"
    success "Removed"
    ;;

  prune)
    [[ $IN_WORKTREE -eq 1 ]] && cd "$GIT_ROOT" >/dev/null
    info "Pruning stale worktrees..."
    git worktree prune -v
    ;;

  ls)
    git worktree list
    echo -e "\n${C_BLUE}Worktrees stored in:${C_RESET} $WORKTREE_BASE" >&2
    ;;

  mv)
    [[ $# -ne 2 ]] && { error "Usage: wt mv <old> <new>"; exit 1; }
    old_user="$1"; new_user="$2"
    old_dir=$(sanitize_name "$old_user")
    new_dir=$(sanitize_name "$new_user")
    old_path="$WORKTREE_BASE/$old_dir"
    new_path="$WORKTREE_BASE/$new_dir"

    [[ ! -d "$old_path" ]] && old_path="$WORKTREE_BASE/$old_user"
    [[ ! -d "$old_path" ]] && { error "Old worktree not found"; exit 1; }
    [[ -d "$new_path" ]] && { error "New worktree already exists"; exit 1; }

    was_current=0
    [[ "$CURRENT_PATH" == "$old_path"* ]] && { was_current=1; cd "$GIT_ROOT" >/dev/null 2>&1; }

    info "Moving '$old_user' → '$new_user' (folder: $old_dir → $new_dir)"
    git worktree move "$old_path" "$new_path"
    git -C "$new_path" branch -m "$old_user" "$new_user" 2>/dev/null || true

    [[ $was_current -eq 1 ]] && echo "$new_path" || success "Moved"
    ;;

  *)
    error "Unknown command: $CMD"
    exit 1
    ;;
esac
