#!/usr/bin/env bash
# wt — Minimal Git Worktree Manager
set -euo pipefail

WT_VERSION="1.0.0"
WT_DIR=".worktree"

# ── Colors ────────────────────────────────────────────────────────────────────
# Do NOT use -t 1: stdout is always a pipe inside $() capture from the shell
# wrapper. Honour TERM / NO_COLOR instead — both survive subshell capture.
RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; DIM=''; NC=''

_setup_colors() {
  [[ "${NO_COLOR:-}" != ""      ]] && return   # https://no-color.org
  [[ "${TERM:-}"     == "dumb"  ]] && return
  [[ -z "${TERM:-}"             ]] && return
  RED=$'\033[0;31m'; GREEN=$'\033[0;32m'; YELLOW=$'\033[1;33m'
  BLUE=$'\033[0;34m'; CYAN=$'\033[0;36m'
  BOLD=$'\033[1m'; DIM=$'\033[2m'; NC=$'\033[0m'
}
_setup_colors

# ── Logging ───────────────────────────────────────────────────────────────────
die()     { printf '%berror:%b %s\n' "$RED"    "$NC" "$*" >&2; exit 1; }
info()    { printf '%b→%b %s\n'     "$CYAN"   "$NC" "$*"; }
success() { printf '%b✓%b %s\n'     "$GREEN"  "$NC" "$*"; }
warn()    { printf '%b⚠%b %s\n'     "$YELLOW" "$NC" "$*"; }

# ── Git helpers ───────────────────────────────────────────────────────────────

require_git() {
  git rev-parse --git-dir &>/dev/null || die "not inside a git repository"
}

# First entry in 'git worktree list' is always the main (non-linked) worktree.
get_main_worktree() {
  git worktree list --porcelain \
    | awk '/^worktree /{print substr($0,10); exit}'
}

# Absolute path of the linked worktree we are currently inside, or "" if main.
get_current_worktree() {
  local top main
  top=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  main=$(get_main_worktree)
  [[ "$top" != "$main" ]] && printf '%s' "$top"
  return 0   # [[ ]] exits 1 when equal; explicit return 0 prevents set -e firing
}

# Given a worktree path, return its branch short name (strips refs/heads/).
# Returns "" for detached HEAD worktrees.
get_worktree_branch() {
  git worktree list --porcelain \
    | awk -v p="$1" '
        /^worktree / { cur = substr($0,10) }
        /^branch /   && cur == p { print substr($0,8); exit }
      ' \
    | sed 's|refs/heads/||'
}

# ── Branch / path helpers ─────────────────────────────────────────────────────

# Sanitize a branch name or commit-ish into a safe directory suffix.
#   feature/my-thing  →  feature-my-thing
#   fix/bug@1.0       →  fix-bug-1.0
#   v3.2.2            →  v3.2.2          (dots kept)
#   388d460           →  388d460
sanitize_branch() {
  printf '%s' "$1" \
    | sed 's|/|-|g' \
    | sed 's|[^a-zA-Z0-9._-]|-|g' \
    | sed 's|^-\+||; s|-\+$||' \
    | sed 's|-\{2,\}|-|g'
}

# Stable repo prefix from origin remote URL, falling back to main worktree
# directory basename.  Used only when CREATING new worktree dirs (add).
repo_name() {
  local name
  name=$(git remote get-url origin 2>/dev/null \
    | sed 's|\.git$||; s|/$||; s|.*[/:]||') || true
  if [[ -z "$name" ]]; then
    name=$(basename "$(get_main_worktree)")
  fi
  printf '%s' "$name"
}

# Resolve a user-supplied name → absolute worktree path by scanning .worktree/.
# Repo-name-agnostic: works regardless of what prefix was used at add-time.
#
# Accepts:  branch name   (feature/login  →  sanitized to feature-login)
#           sanitized     (feature-login)
#           tag / SHA     (v3.2.2 / 388d460)
#           exact dir     (dotfiles.feature-login)
resolve_wt_path() {
  local name="$1"
  local main wt_dir san d base

  main=$(get_main_worktree)
  wt_dir="$main/$WT_DIR"
  [[ -d "$wt_dir" ]] || return 1

  san=$(sanitize_branch "$name")

  # Scan every directory; match on sanitized suffix (prefix-agnostic).
  for d in "$wt_dir"/*/; do
    [[ -d "$d" ]] || continue
    base=$(basename "$d")
    if [[ "$base" == *".$san" || "$base" == "$san" ]]; then
      printf '%s' "${d%/}"
      return 0
    fi
  done

  # Literal fallback (user passed the exact directory name).
  [[ -d "$wt_dir/$name" ]] && { printf '%s' "$wt_dir/$name"; return 0; }

  return 1
}

# Ensure .worktree is listed in .git/info/exclude (idempotent).
ensure_excluded() {
  local main exclude_file
  main=$(get_main_worktree)
  exclude_file="$main/.git/info/exclude"
  [[ -f "$exclude_file" ]] || return 0
  if ! grep -qxF "/$WT_DIR" "$exclude_file" 2>/dev/null; then
    printf '/%s\n' "$WT_DIR" >> "$exclude_file"
    info "added /$WT_DIR to .git/info/exclude"
  fi
}

# Delete a branch by name; warn if it cannot be deleted (e.g. not local).
# Silently skips when branch is empty (detached HEAD worktrees).
delete_branch() {
  local branch="$1" main="$2"
  [[ -z "$branch" ]] && return 0
  if git -C "$main" branch -D "$branch" 2>/dev/null; then
    success "deleted branch ${BOLD}${branch}${NC}"
  else
    warn "could not delete branch ${BOLD}${branch}${NC} (not a local branch or already gone)"
  fi
}

# Emit a cd directive intercepted by the shell wrapper (invisible to user).
emit_cd() { printf '__WT_CD__:%s\n' "$1"; }

# ── Commands ──────────────────────────────────────────────────────────────────

# wt init
# Outputs a POSIX-compatible shell function for eval; works in bash and zsh.
#
# Single invocation: capture stdout only. stderr flows to the terminal so git
# progress ("Preparing worktree…") is visible live. nuke prompt uses /dev/tty.
cmd_init() {
  cat <<'SHELL_FUNC'
wt() {
  local _out _ret _cd
  # Single invocation — stdout captured; stderr goes straight to terminal.
  _out=$(command wt "$@")
  _ret=$?

  # Extract optional cd directive (last one wins).
  _cd=$(printf '%s\n' "$_out" | grep '^__WT_CD__:' | tail -1 | sed 's/^__WT_CD__://')

  # Print all output lines except the hidden directive.
  printf '%s\n' "$_out" | grep -v '^__WT_CD__:' || true

  # Perform directory change in the current shell process.
  if [ -n "$_cd" ] && [ -d "$_cd" ]; then
    cd "$_cd" || return 1
  fi

  return $_ret
}
SHELL_FUNC
}

# wt add <branch|commit-ish>
#
# Resolution order:
#   1. Local branch exists              → check it out on the branch
#   2. Valid commit-ish (tag, SHA, …)   → detached HEAD
#   3. Nothing found                    → create a new local branch
cmd_add() {
  local ref="${1:-}"
  [[ -z "$ref" ]] && die "usage: wt add <branch|commit-ish>"

  require_git
  local main prefix san wt_name wt_path
  main=$(get_main_worktree)
  prefix=$(repo_name)
  san=$(sanitize_branch "$ref")
  wt_name="${prefix}.${san}"
  wt_path="$main/$WT_DIR/$wt_name"

  # Idempotent: already exists → just cd there.
  if [[ -d "$wt_path" ]]; then
    info "already at ${BOLD}${wt_name}${NC}"
    emit_cd "$wt_path"
    return 0
  fi

  mkdir -p "$main/$WT_DIR"
  ensure_excluded

  if git -C "$main" show-ref --verify --quiet "refs/heads/$ref" 2>/dev/null; then
    # ── Case 1: existing local branch ─────────────────────────────────────
    info "creating worktree ${BOLD}${wt_name}${NC}  (branch: ${BOLD}${ref}${NC})"
    git -C "$main" worktree add "$wt_path" "$ref"

  elif git -C "$main" rev-parse --verify "${ref}^{commit}" &>/dev/null; then
    # ── Case 2: commit-ish (tag, SHA, remote ref, …) ── detached HEAD ─────
    local resolved
    resolved=$(git -C "$main" rev-parse --short "${ref}^{commit}" 2>/dev/null)
    info "creating worktree ${BOLD}${wt_name}${NC}  (detached at ${BOLD}${ref}${NC} = ${DIM}${resolved}${NC})"
    git -C "$main" worktree add --detach "$wt_path" "$ref"

  else
    # ── Case 3: new branch ────────────────────────────────────────────────
    info "branch ${BOLD}${ref}${NC} not found locally — creating it"
    info "creating worktree ${BOLD}${wt_name}${NC}  (new branch: ${BOLD}${ref}${NC})"
    git -C "$main" worktree add -b "$ref" "$wt_path"
  fi

  success "ready at ${BOLD}${wt_path}${NC}"
  emit_cd "$wt_path"
}

# wt rm [-f] [-D] [branch|commit-ish]
#
#   -f   force removal (uncommitted changes present)
#   -D   also delete the associated local branch after removal
#        (silently skipped for detached HEAD worktrees)
cmd_rm() {
  local force=0 del_branch=0 target=""
  for arg in "$@"; do
    case "$arg" in
      -f|--force)       force=1 ;;
      -D|--delete-branch) del_branch=1 ;;
      *)                target="$arg" ;;
    esac
  done

  require_git
  local main wt_path
  main=$(get_main_worktree)

  if [[ -z "$target" ]]; then
    wt_path=$(get_current_worktree)
    [[ -z "$wt_path" ]] \
      && die "not inside a managed worktree — specify a name: wt rm <branch>"
  else
    wt_path=$(resolve_wt_path "$target") \
      || die "worktree not found: $target"
  fi

  local was_here=0
  local cur
  cur=$(get_current_worktree)
  [[ "$cur" == "$wt_path" ]] && was_here=1

  # Capture branch BEFORE removing the worktree.
  local branch
  branch=$(get_worktree_branch "$wt_path")
  local branch_note="${branch:-(detached HEAD)}"
  info "removing ${BOLD}$(basename "$wt_path")${NC}  (${branch_note})"

  local git_args=()
  [[ $force -eq 1 ]] && git_args+=(--force)

  # Change process CWD to $main before calling git when we are inside the
  # worktree being removed (some git versions refuse otherwise).
  if [[ $was_here -eq 1 ]]; then
    ( cd "$main" && git worktree remove "${git_args[@]}" "$wt_path" )
  else
    git -C "$main" worktree remove "${git_args[@]}" "$wt_path"
  fi
  success "worktree removed"

  if [[ $del_branch -eq 1 ]]; then delete_branch "$branch" "$main"; fi

  if [[ $was_here -eq 1 ]]; then emit_cd "$main"; fi
}

# wt prune
cmd_prune() {
  require_git
  info "pruning stale worktree references"
  git worktree prune --verbose
  success "done"
}

# wt nuke [-f] [-D]
#
#   -f   skip confirmation prompt
#   -D   also delete the associated local branch for each worktree
#        (detached HEAD worktrees are skipped silently)
#
# Without -D only the worktree directories are removed; branches are kept.
cmd_nuke() {
  local force=0 del_branch=0
  for arg in "$@"; do
    case "$arg" in
      -f|--force)         force=1 ;;
      -D|--delete-branch) del_branch=1 ;;
    esac
  done

  require_git
  local main
  main=$(get_main_worktree)

  # Collect all non-main worktrees + their branches before touching anything.
  local -a paths=() branches=()
  local _path="" _branch=""

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)  _path="${line#worktree }" ;;
      "branch "*)    _branch="${line#branch refs/heads/}" ;;
      "")
        if [[ -n "$_path" && "$_path" != "$main" ]]; then
          paths+=("$_path")
          branches+=("${_branch:-}")
        fi
        _path=""; _branch=""
        ;;
    esac
  done < <(git worktree list --porcelain; printf '\n')

  if [[ ${#paths[@]} -eq 0 ]]; then
    info "no linked worktrees to remove"
    return 0
  fi

  printf '\n%bWorktrees to be nuked:%b\n' "$BOLD" "$NC"
  local p
  for p in "${paths[@]}"; do
    printf '  %b✗%b %-40s  %b%s%b\n' \
      "$RED" "$NC" "$(basename "$p")" "$DIM" "$p" "$NC"
  done
  [[ $del_branch -eq 1 ]] \
    && printf '  %b(branches will also be deleted)%b\n' "$YELLOW" "$NC"
  printf '\n'

  if [[ $force -eq 0 ]]; then
    printf '%bnuke all worktrees%b%s%b [y/N] ' \
      "$YELLOW" "$NC" \
      "$( [[ $del_branch -eq 1 ]] && printf ' and their branches?' || printf '?' )" \
      "$NC" >/dev/tty
    local confirm
    read -r confirm </dev/tty
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      info "aborted"
      return 0
    fi
  fi

  local cur was_in_wt=0
  cur=$(get_current_worktree)
  [[ -n "$cur" ]] && was_in_wt=1

  local i
  for i in "${!paths[@]}"; do
    local wtp="${paths[$i]}"
    local b="${branches[$i]:-}"
    info "removing ${BOLD}$(basename "$wtp")${NC}"
    ( cd "$main" && git worktree remove --force "$wtp" ) 2>/dev/null || true
    if [[ $del_branch -eq 1 ]]; then delete_branch "$b" "$main"; fi
  done

  git -C "$main" worktree prune 2>/dev/null || true
  success "all worktrees nuked"

  if [[ $was_in_wt -eq 1 ]]; then emit_cd "$main"; fi
}

# wt ls
# Two-pass: collect → compute column width → render.
# ANSI alignment rule: pad plain text FIRST, then apply color codes.
# [main] badge goes at END of line so SHA + branch columns stay aligned.
cmd_ls() {
  require_git

  local cur_top main_top
  cur_top=$(git rev-parse --show-toplevel 2>/dev/null || printf '')
  main_top=$(get_main_worktree)

  # ── Pass 1: collect ────────────────────────────────────────────────────
  local -a all_paths=() all_heads=() all_branches=() all_is_main=()
  local _path="" _head="" _branch="" _detached=0

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        _path="${line#worktree }"; _head=""; _branch=""; _detached=0 ;;
      "HEAD "*)    _head="${line#HEAD }" ;;
      "branch "*)  _branch="${line#branch refs/heads/}" ;;
      "detached")  _detached=1 ;;
      "bare")      _branch="(bare)" ;;
      "")
        if [[ -n "$_path" ]]; then
          all_paths+=("$_path")
          all_heads+=("${_head:0:7}")
          if [[ $_detached -eq 1 ]]; then
            all_branches+=("HEAD (detached)")
          else
            all_branches+=("${_branch:-}")
          fi
          [[ "$_path" == "$main_top" ]] && all_is_main+=(1) || all_is_main+=(0)
        fi
        _path=""; _head=""; _branch=""; _detached=0
        ;;
    esac
  done < <(git worktree list --porcelain; printf '\n')

  # ── Pass 1b: name column width (plain chars only, cap at 50) ──────────
  local max_label=4
  local p lbl len
  for p in "${all_paths[@]}"; do
    lbl=$(basename "$p")
    len=${#lbl}
    [[ $len -gt 50 ]] && len=50
    [[ $len -gt $max_label ]] && max_label=$len
  done
  local col_width=$(( max_label + 1 ))

  # ── Pass 2: render ────────────────────────────────────────────────────
  printf '\n%bWorktrees%b\n\n' "$BOLD" "$NC"

  local i head branch is_cur is_main label display marker color branch_color badge padded
  for i in "${!all_paths[@]}"; do
    p="${all_paths[$i]}"
    head="${all_heads[$i]}"
    branch="${all_branches[$i]}"
    label=$(basename "$p")
    is_main="${all_is_main[$i]}"
    [[ "$p" == "$cur_top" ]] && is_cur=1 || is_cur=0

    display="$label"
    [[ ${#label} -gt 50 ]] && display="${label:0:47}..."

    if [[ $is_cur -eq 1 ]]; then
      marker="${GREEN}▶${NC}"; color="$BOLD"; branch_color="$CYAN"
    else
      marker="${DIM}◦${NC}";  color="$DIM";  branch_color="$BLUE"
    fi

    # [main] badge AFTER branch — sha column stays aligned across all rows.
    [[ $is_main -eq 1 ]] && badge="  ${DIM}[main]${NC}" || badge=""

    # Pad plain text first, color second.
    padded=$(printf "%-${col_width}s" "$display")

    printf '  %b%b %b%s%b  %b%s%b  %b%s%b%s\n' \
      "$marker" "$NC" \
      "$color"  "$padded" "$NC" \
      "$DIM"    "$head"   "$NC" \
      "$branch_color" "${branch:-(detached)}" "$NC" \
      "$badge"
  done

  printf '\n'
}

# wt mv [-D] <from> <to>
#
#   -D   also rename the associated local branch from <from> to <to>
#        (silently skipped for detached HEAD worktrees)
cmd_mv() {
  local del_branch=0
  local -a positional=()
  for arg in "$@"; do
    case "$arg" in
      -D|--delete-branch) del_branch=1 ;;
      *) positional+=("$arg") ;;
    esac
  done

  local from="${positional[0]:-}" to="${positional[1]:-}"
  [[ -z "$from" || -z "$to" ]] && die "usage: wt mv [-D] <from> <to>"

  require_git
  local main to_san to_path from_path prefix
  main=$(get_main_worktree)

  from_path=$(resolve_wt_path "$from") \
    || die "source worktree not found: $from"

  # Capture branch BEFORE the move (git mv doesn't change the branch).
  local old_branch
  old_branch=$(get_worktree_branch "$from_path")

  # Derive destination prefix from the SOURCE dir so names stay consistent.
  local from_base
  from_base=$(basename "$from_path")
  if [[ "$from_base" == *.* ]]; then
    prefix="${from_base%%.*}"
  else
    prefix=$(repo_name)
  fi

  to_san=$(sanitize_branch "$to")
  to_path="$main/$WT_DIR/${prefix}.${to_san}"

  local was_here=0
  local cur
  cur=$(get_current_worktree)
  [[ "$cur" == "$from_path" ]] && was_here=1

  info "moving ${BOLD}$(basename "$from_path")${NC} → ${BOLD}$(basename "$to_path")${NC}"
  git -C "$main" worktree move "$from_path" "$to_path"
  success "worktree moved"

  if [[ $del_branch -eq 1 ]]; then
    if [[ -n "$old_branch" ]]; then
      # Derive new branch name from the <to> argument (keep slash-style if
      # the user passed a slash, otherwise use sanitized form as-is).
      local new_branch="$to"
      info "renaming branch ${BOLD}${old_branch}${NC} → ${BOLD}${new_branch}${NC}"
      if git -C "$main" branch -m "$old_branch" "$new_branch" 2>/dev/null; then
        success "branch renamed"
      else
        warn "could not rename branch ${BOLD}${old_branch}${NC} → ${BOLD}${new_branch}${NC}"
      fi
    else
      warn "worktree is in detached HEAD state — no branch to rename"
    fi
  fi

  if [[ $was_here -eq 1 ]]; then emit_cd "$to_path"; fi
}

# wt co <branch|commit-ish>
cmd_co() {
  local target="${1:-}"
  [[ -z "$target" ]] && die "usage: wt co <branch|commit-ish>"

  require_git
  local wt_path
  wt_path=$(resolve_wt_path "$target") \
    || die "worktree not found: $target  (use 'wt add $target' to create it)"

  emit_cd "$wt_path"
}

# wt help
cmd_help() {
  printf '\n'
  printf '%bwt%b — Git Worktree Manager %b v%s%b\n\n' \
    "$BOLD" "$NC" "$DIM" "$WT_VERSION" "$NC"
  printf '%bUSAGE%b\n'    "$BOLD" "$NC"
  printf '  wt <command> [options]\n\n'
  printf '%bCOMMANDS%b\n' "$BOLD" "$NC"
  printf '  %binit%b                        Output shell function for auto-cd support\n'  "$CYAN" "$NC"
  printf '  %badd%b  <branch|commit-ish>    Add a new worktree\n'                          "$CYAN" "$NC"
  printf '  %brm%b   [-f] [-D] [name]       Remove current or named worktree\n'            "$CYAN" "$NC"
  printf '  %bco%b   <name>                 Switch into a worktree (cd)\n'                 "$CYAN" "$NC"
  printf '  %bls%b                          List all worktrees\n'                           "$CYAN" "$NC"
  printf '  %bmv%b   [-D] <from> <to>       Move / rename a worktree\n'                    "$CYAN" "$NC"
  printf '  %bprune%b                       Prune stale worktree references\n'              "$CYAN" "$NC"
  printf '  %bnuke%b  [-f] [-D]             Remove ALL worktrees\n\n'                      "$CYAN" "$NC"
  printf '%bFLAGS%b\n' "$BOLD" "$NC"
  printf '  %b-f%b   Force  (rm/nuke: allow dirty worktrees)\n'          "$CYAN" "$NC"
  printf '  %b-D%b   Branch (rm: delete branch; mv: rename branch;\n'    "$CYAN" "$NC"
  printf '              nuke: delete all branches)\n\n'
  printf '%bADD RESOLUTION ORDER%b\n' "$BOLD" "$NC"
  printf '  1. Local branch exists        → check out on that branch\n'
  printf '  2. Valid commit-ish (tag/SHA) → detached HEAD\n'
  printf '  3. Unknown name               → create new local branch\n\n'
  printf '%bWORKTREE LOCATION%b\n'  "$BOLD" "$NC"
  printf '  <repo-root>/.worktree/<repo-name>.<sanitized-ref>\n'
  printf '  e.g.  feature/login  →  myrepo.feature-login\n'
  printf '        v3.2.2         →  myrepo.v3.2.2\n'
  printf '        388d460        →  myrepo.388d460\n\n'
  printf '%bSETUP%b\n'   "$BOLD" "$NC"
  printf '  Add to ~/.bashrc or ~/.zshrc:\n\n'
  printf '    %beval "$(wt init)"%b\n\n' "$DIM" "$NC"
  printf '%bEXAMPLES%b\n' "$BOLD" "$NC"
  printf '  %bwt add feature/login%b    Create worktree for branch\n'          "$DIM" "$NC"
  printf '  %bwt add v3.2.2%b           Detached worktree at tag v3.2.2\n'     "$DIM" "$NC"
  printf '  %bwt add 388d460%b          Detached worktree at commit\n'         "$DIM" "$NC"
  printf '  %bwt co  feature/login%b    Switch into that worktree\n'           "$DIM" "$NC"
  printf '  %bwt ls%b                   Show all worktrees\n'                  "$DIM" "$NC"
  printf '  %bwt rm%b                   Remove current worktree\n'             "$DIM" "$NC"
  printf '  %bwt rm -D feature/x%b      Remove worktree + delete branch\n'    "$DIM" "$NC"
  printf '  %bwt mv -D old new%b        Rename worktree + rename branch\n'    "$DIM" "$NC"
  printf '  %bwt nuke%b                 Remove all worktrees (keep branches)\n' "$DIM" "$NC"
  printf '  %bwt nuke -D%b              Remove all worktrees + delete branches\n' "$DIM" "$NC"
  printf '  %bwt nuke -f -D%b           Same, no confirmation\n'              "$DIM" "$NC"
  printf '\n'
}

# ── Entry point ───────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)                  cmd_init              ;;
    add)                   cmd_add      "$@"     ;;
    rm|remove)             cmd_rm       "$@"     ;;
    co|checkout)           cmd_co       "$@"     ;;
    ls|list)               cmd_ls                ;;
    mv|move)               cmd_mv       "$@"     ;;
    prune)                 cmd_prune             ;;
    nuke)                  cmd_nuke     "$@"     ;;
    help|-h|--help)        cmd_help              ;;
    version|-V|--version)  printf 'wt %s\n' "$WT_VERSION" ;;
    *) die "unknown command: '$cmd'  (run 'wt help')" ;;
  esac
}

main "$@"
