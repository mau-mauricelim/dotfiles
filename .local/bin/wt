#!/usr/bin/env bash
# =============================================================================
#  wt — Git Worktree Manager
#  Version: 1.0.0
#
#  IMPORTANT: For `cd` to work, you must source the shell integration.
#  Run `wt install` to set it up, or manually add to your shell rc:
#
#    source /path/to/wt.init.sh
#
#  Without shell integration, all commands still work EXCEPT navigation (cd).
# =============================================================================

set -uo pipefail

# ── Colours ──────────────────────────────────────────────────────────────────

# Colour detection:
# When invoked via the wt shell function, stdout is redirected to a temp
# file so [ -t 1 ] is always false -- even though the user's terminal is
# right there. The shell function sets WT_COLOR=1 to preserve intent.
# Direct invocation still works via the [ -t 1 ] fallback.
if [[ "${WT_COLOR:-}" == "1" || -t 1 ]]; then
  # $'...' (ANSI C quoting) embeds the real ESC byte at assignment time.
  # This works in bash AND zsh, and means the variables work correctly
  # inside echo, printf, cat <<EOF, and anywhere else — no -e flag needed.
  RED=$'\033[0;31m'
  GREEN=$'\033[0;32m'
  YELLOW=$'\033[1;33m'
  BLUE=$'\033[0;34m'
  CYAN=$'\033[0;36m'
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  NC=$'\033[0m'
else
  RED='' GREEN='' YELLOW='' BLUE='' CYAN='' BOLD='' DIM='' NC=''
fi

# ── Logging helpers ───────────────────────────────────────────────────────────

info()    { printf "  ${BLUE}→${NC} %b\n" "$*"; }
success() { printf "  ${GREEN}✔${NC}  %b\n" "$*"; }
warn()    { printf "  ${YELLOW}⚠${NC}  %b\n" "$*"; }
error()   { printf "  ${RED}✖${NC}  %b\n" "$*" >&2; }
die()     { error "$*"; exit 1; }
header()  { printf "\n${BOLD}${CYAN}%b${NC}\n" "$*"; }
dim()     { printf "  ${DIM}%b${NC}\n" "$*"; }

# ── Git helpers ───────────────────────────────────────────────────────────────

# Print repo root, or die if not in a git repo.
git_root() {
  # IMPORTANT: git rev-parse --show-toplevel returns the *current worktree's*
  # root, not the main repo root. When called from inside a linked worktree
  # (e.g. ${worktree_rel}/repo.feature-login), it returns that subdirectory —
  # causing all subsequent paths to nest incorrectly.
  #
  # The main repo is always the FIRST entry in git worktree list.
  #
  # NOTE: we capture the awk output into a variable rather than using
  # `pipeline || die` directly. With `set -o pipefail`, when awk exits early
  # (after its first match), git receives SIGPIPE and exits non-zero, making
  # the whole pipeline non-zero and triggering a spurious die. Capturing first
  # then checking for empty avoids this.
  git rev-parse --git-dir >/dev/null 2>&1 || die "Not inside a git repository"
  local _root
  _root="$(git worktree list --porcelain 2>/dev/null | awk '/^worktree /{print substr($0,10); exit}')" || true
  [[ -n "$_root" ]] || die "Could not determine repo root"
  printf '%s\n' "$_root"
}

# Print repo name (basename of root).
repo_name() {
  basename "$(git_root)"
}

# Print the base directory where all managed worktrees live.
worktree_rel=".worktrees"
worktree_base() {
  echo "$(git_root)/${worktree_rel}"
}

# Sanitize a branch name for use as a directory component.
# Replaces '/' with '-' so feature/auth → feature-auth.
sanitize_branch() {
  echo "${1}" | tr '/' '-' | tr ' ' '_'
}

# Print the full managed worktree path for a given branch.
worktree_path() {
  local branch="${1}"
  local safe_branch
  safe_branch="$(sanitize_branch "$branch")"
  echo "$(worktree_base)/$(repo_name).${safe_branch}"
}

# Check if a branch exists locally.
branch_exists() {
  git show-ref --verify --quiet "refs/heads/${1}"
}

# If the current directory is inside a managed worktree, print the original
# branch name (from git worktree list). Prints empty string if not in one.
current_worktree_branch() {
  local cwd
  cwd="$(pwd -P 2>/dev/null || pwd)"
  local base
  base="$(worktree_base)"

  # Fast path: not even inside the ${worktree_rel} dir
  case "$cwd" in
    "$base"/*) ;;
    *) echo ""; return 0 ;;
  esac

  # Walk git worktree list to find a registered worktree whose path
  # is a prefix of (or equal to) cwd.
  local found_branch=""
  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        current_wt_path="${line#worktree }"
        ;;
      "branch "*)
        current_wt_branch="${line#branch refs/heads/}"
        ;;
      "")
        if [[ -n "${current_wt_path:-}" ]]; then
          case "$cwd" in
            "$current_wt_path"|"$current_wt_path"/*)
              found_branch="${current_wt_branch:-}"
              ;;
          esac
        fi
        current_wt_path=""
        current_wt_branch=""
        ;;
    esac
  done < <(git worktree list --porcelain; echo "")

  echo "$found_branch"
}

# ── Signal mechanism ──────────────────────────────────────────────────────────
#
# Because a subprocess cannot change the parent shell's directory, we emit a
# special token on stdout. The shell wrapper function (wt.init.sh) intercepts
# it and performs the `cd` on our behalf.

signal_cd() {
  echo "__WT_CD__:${1}"
}

# ── Commands ──────────────────────────────────────────────────────────────────

# wt add <branch>
# Creates a new managed worktree for <branch>.
# If the branch doesn't exist yet it is created.
cmd_add() {
  local branch="${1:-}"
  [[ -z "$branch" ]] && die "Usage: wt add <branch>"

  local root base path
  root="$(git_root)"
  base="$(worktree_base)"
  path="$(worktree_path "$branch")"

  # Guard: already exists
  if [[ -d "$path" ]]; then
    warn "Worktree directory already exists: ${path}"
    warn "Run 'wt co ${branch}' to navigate to it"
    exit 1
  fi

  # Guard: another worktree is already tracking that branch
  if git worktree list --porcelain | grep -q "^branch refs/heads/${branch}$"; then
    die "Branch '${branch}' is already checked out in another worktree"
  fi

  header "Adding worktree"
  info "Branch : ${branch}"
  info "Path   : ${path}"
  echo ""

  mkdir -p "$base"

  if branch_exists "$branch"; then
    git worktree add "$path" "$branch" 2>&1 \
      || die "git worktree add failed"
  else
    warn "Branch '${branch}' not found locally — creating it"
    git worktree add -b "$branch" "$path" 2>&1 \
      || die "git worktree add -b failed"
  fi

  echo ""
  success "Worktree ready"
  signal_cd "$path"
}

# wt rm [branch]
# Remove a managed worktree.
#   No argument → removes the worktree you are currently inside.
#   With <branch> → removes that specific worktree.
cmd_remove() {
  local branch="${1:-}"
  local root
  root="$(git_root)"

  if [[ -z "$branch" ]]; then
    branch="$(current_worktree_branch)"
    [[ -z "$branch" ]] && die \
      "Not currently inside a managed worktree.\nSpecify a branch: wt rm <branch>"
  fi

  local path
  path="$(worktree_path "$branch")"

  [[ -d "$path" ]] || die "No worktree found at: ${path}"

  # If we are inside the worktree being removed, we must leave first.
  local cwd
  cwd="$(pwd -P 2>/dev/null || pwd)"
  local needs_cd=false
  case "$cwd" in
    "$path"|"$path"/*) needs_cd=true ;;
  esac

  header "Removing worktree"
  info "Branch : ${branch}"
  info "Path   : ${path}"
  echo ""

  # Try clean remove, fall back to --force (handles dirty trees with a warning)
  if ! git worktree remove "$path" 2>&1; then
    warn "Worktree has local changes — forcing removal"
    git worktree remove --force "$path" 2>&1 \
      || die "git worktree remove failed"
  fi

  echo ""
  success "Worktree '${branch}' removed"

  if $needs_cd; then
    info "Returning to repo root"
    signal_cd "$root"
  fi
}

# wt prune
# Prune all stale worktree administrative files.
# If currently in any managed worktree, navigates to repo root first.
cmd_prune() {
  local root
  root="$(git_root)"

  local current
  current="$(current_worktree_branch)"
  local needs_cd=false
  [[ -n "$current" ]] && needs_cd=true

  header "Pruning stale worktrees"
  if $needs_cd; then
    info "Currently on worktree '${current}' — will return to repo root"
  fi
  echo ""

  git worktree prune --verbose \
    || die "git worktree prune failed"

  echo ""
  success "Prune complete"

  if $needs_cd; then
    info "Returning to repo root"
    signal_cd "$root"
  fi
}

# wt ls
# Pretty-print all worktrees for this repo.
cmd_list() {
  local root base
  root="$(git_root)"
  base="$(worktree_base)"

  header "Worktrees — $(repo_name)"
  echo ""

  # Column widths
  local max_path=6   # min "Path"
  local max_branch=6 # min "Branch"

  # First pass: collect data and compute widths
  declare -a wt_paths wt_hashes wt_branches wt_flags
  local idx=0
  local cur_path="" cur_hash="" cur_branch="" cur_flags=""

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)  cur_path="${line#worktree }" ;;
      "HEAD "*)      cur_hash="${line#HEAD }" ;;
      "branch "*)    cur_branch="${line#branch refs/heads/}" ;;
      "bare")        cur_flags="bare" ;;
      "detached")    cur_branch="(detached)" ;;
      "")
        if [[ -n "$cur_path" ]]; then
          wt_paths[$idx]="$cur_path"
          wt_hashes[$idx]="${cur_hash:0:7}"
          wt_branches[$idx]="${cur_branch:-?}"
          wt_flags[$idx]="${cur_flags:-}"

          (( ${#cur_path} > max_path ))   && max_path="${#cur_path}"
          (( ${#cur_branch} > max_branch )) && max_branch="${#cur_branch}"

          (( idx++ ))
          cur_path=""; cur_hash=""; cur_branch=""; cur_flags=""
        fi
        ;;
    esac
  done < <(git worktree list --porcelain; echo "")

  # Determine cwd for highlighting
  local cwd
  cwd="$(pwd -P 2>/dev/null || pwd)"

  # Header row
  printf "  ${BOLD}%-*s  %-7s  %-*s${NC}\n" \
    "$max_path" "Path" "Commit" "$max_branch" "Branch"
  printf "  %s  %s  %s\n" \
    "$(printf '─%.0s' $(seq 1 $max_path))" \
    "───────" \
    "$(printf '─%.0s' $(seq 1 $max_branch))"

  # Data rows
  local i
  for i in "${!wt_paths[@]}"; do
    local p="${wt_paths[$i]}"
    local h="${wt_hashes[$i]}"
    local b="${wt_branches[$i]}"
    local f="${wt_flags[$i]}"

    # Highlight current worktree
    local marker="  "
    local path_color="$DIM"
    case "$cwd" in
      "$p"|"$p"/*)
        marker="${GREEN}▶${NC} "
        path_color="${CYAN}"
        ;;
    esac

    local branch_color="$NC"
    [[ "$b" == "(detached)" ]] && branch_color="$YELLOW"
    [[ "$f" == "bare" ]]       && branch_color="$YELLOW" && b="(bare)"

    printf "${marker}${path_color}%-*s${NC}  ${DIM}%s${NC}  ${branch_color}%-*s${NC}\n" \
      "$max_path" "$p" "$h" "$max_branch" "$b"
  done

  echo ""

  # Summary of managed worktrees
  local managed=0
  [[ -d "$base" ]] && managed=$(find "$base" -maxdepth 1 -mindepth 1 -type d 2>/dev/null | wc -l | tr -d ' ')
  dim "Managed in ${worktree_rel}/: ${managed}  |  Repo root: ${root}"
  echo ""
}

# wt mv <from-branch> <to-branch>
# Move/rename a managed worktree, updating git's tracking data.
# If you are currently in the worktree being moved, navigates to the new path.
cmd_move() {
  local from="${1:-}" to="${2:-}"
  [[ -z "$from" || -z "$to" ]] && die "Usage: wt mv <from-branch> <to-branch>"

  local from_path to_path base
  from_path="$(worktree_path "$from")"
  to_path="$(worktree_path "$to")"
  base="$(worktree_base)"

  [[ -d "$from_path" ]] || die "No worktree found for branch '${from}' at: ${from_path}"
  [[ -d "$to_path" ]]   && die "Destination already exists: ${to_path}"

  # Check if we are currently in the worktree being moved
  local cwd
  cwd="$(pwd -P 2>/dev/null || pwd)"
  local was_inside=false
  case "$cwd" in
    "$from_path"|"$from_path"/*) was_inside=true ;;
  esac

  header "Moving worktree"
  info "From : ${from_path}"
  info "To   : ${to_path}"
  echo ""

  mkdir -p "$base"
  git worktree move "$from_path" "$to_path" 2>&1 \
    || die "git worktree move failed"

  echo ""
  success "Moved successfully"

  if $was_inside; then
    # Preserve relative sub-path within the worktree
    local rel="${cwd#$from_path}"
    local new_cwd="${to_path}${rel}"
    [[ -d "$new_cwd" ]] || new_cwd="$to_path"
    info "Updating location to new path"
    signal_cd "$new_cwd"
  fi
}

# wt co <branch>
# Navigate into a managed worktree. Requires shell integration.
cmd_checkout() {
  local branch="${1:-}"
  [[ -z "$branch" ]] && die "Usage: wt co <branch>"

  local path
  path="$(worktree_path "$branch")"

  if [[ ! -d "$path" ]]; then
    error "No managed worktree found for '${branch}'"
    info  "Available worktrees:"
    cmd_list
    echo ""
    die "Did you mean:  wt add ${branch}"
  fi

  info "Switching to worktree '${branch}'"
  signal_cd "$path"
}

# wt install
# Appends the wt shell function to bash/zsh rc file
cmd_install() {
  # ── Resolve true home ──────────────────────────────────────────────────
  local true_home
  if command -v getent &>/dev/null; then
    true_home="$(getent passwd "$(id -un)" | cut -d: -f6)"
  elif command -v dscl &>/dev/null; then          # macOS
    true_home="$(dscl . -read "/Users/$(id -un)" NFSHomeDirectory 2>/dev/null | awk '{print $2}')"
  fi
  true_home="${true_home:-$HOME}"   # fallback to $HOME if all else fails

  # ── Resolve rc files ───────────────────────────────────────────────────
  local bashrc="${true_home}/.bashrc"
  local zshrc="${ZDOTDIR:-${true_home}}/.zshrc"   # respect ZDOTDIR

  # ── Check login shell to warn if neither bash nor zsh ─────────────────
  local login_shell
  if command -v getent &>/dev/null; then
    login_shell="$(getent passwd "$(id -un)" | cut -d: -f7)"
  else
    login_shell="${SHELL:-unknown}"
  fi

  case "$login_shell" in
    */bash|*/zsh) ;;
    *) warn "Login shell is '${login_shell}' — only bash/zsh rc files will be modified" ;;
  esac

  # ── Write source lines ─────────────────────────────────────────────────
  local shell_src="$(dirname "$0")/../lib/wt.init.sh"

  header "Installing wt shell integration"
  echo ""

  if [[ ! -f "$shell_src" ]]; then
    die "wt.init.sh not found next to the wt script.\nExpected: ${shell_src}"
  fi

  local installed=0

  # Replace "/home/<user>" with "$HOME"
  shell_src="${shell_src/#$HOME/\$HOME}"
  printf -v shell_cmd '\n# wt — Git Worktree Manager\n[ -f "%s" ] && source "%s"\n' \
    "$shell_src" "$shell_src"

  info "Adding the following lines to bash/zsh rc files:"
  echo ""
  shell_diff="${shell_cmd//[$'\n']/$'\n'+}"
  printf "%s" "${GREEN}+${shell_diff%+}"
  echo ""

  for rc in "$bashrc" "$zshrc"; do
    [[ -f "$rc" ]] || continue
    if grep -qF "wt.init.sh" "$rc" 2>/dev/null; then
      warn "Already installed in ${rc} — skipping"
    else
      printf "%s" "$shell_cmd" >> "$rc"
      success "Added to ${rc}"
      (( installed++ ))
    fi
  done
  # TODO: Install man?

  # ── If neither file was touched, give manual instructions ──────────────
  if [[ $installed -eq 0 ]]; then
    warn "No rc files modified"
    echo ""
    info  "Manually add to your shell's rc file:"
    printf '\n    source "%s"\n\n' "$shell_src"
  fi
}

# wt help
cmd_help() {
  cat <<EOF

${BOLD}${CYAN}wt${NC} — Git Worktree Manager  ${DIM}v1.0.0${NC}

${BOLD}USAGE${NC}
  wt <command> [arguments]

${BOLD}COMMANDS${NC}

  ${GREEN}add${NC} <branch>
      Create a new managed worktree for <branch>.
      Automatically creates the branch if it doesn't exist locally.
      Then navigates into the new worktree directory.

      Path: <repo-root>/${worktree_rel}/<repo-name>.<branch>

  ${GREEN}rm${NC} [branch]
      Remove a managed worktree.
        wt rm              → removes the worktree you are currently inside
        wt rm <branch>     → removes a specific worktree by branch name
      If the tree has uncommitted changes, removal is forced with a warning.
      Navigates back to repo root if you were inside the removed worktree.

  ${GREEN}prune${NC}
      Remove stale/dead worktree administrative files (git bookkeeping).
      Equivalent to: git worktree prune --verbose
      Navigates to repo root if currently in any managed worktree.

  ${GREEN}ls${NC}
      List all worktrees with path, short commit hash, and branch name.
      Highlights the worktree you are currently in with ${GREEN}▶${NC}.

  ${GREEN}mv${NC} <from-branch> <to-branch>
      Move (rename) a managed worktree's directory and update git's tracking.
      If you are currently inside the renamed worktree, navigates to the
      new location automatically.

  ${GREEN}co${NC} <branch>
      Navigate into a managed worktree for <branch>.
      Requires shell integration. Use 'wt install' to set it up.

  ${GREEN}install${NC}
      Append shell integration to ~/.bashrc and/or ~/.zshrc so that
      commands that need to change directory (add, rm, co, mv, prune)
      actually work in your current shell session.

  ${GREEN}help${NC}  (-h, --help)
      Show this help message.

${BOLD}HOW DIRECTORY CHANGES WORK${NC}
  Bash scripts run in a subshell and cannot change the parent shell's
  directory. wt solves this with a thin shell wrapper function. The binary
  signals the desired path; the wrapper performs the actual 'cd'.

  Run ${CYAN}wt install${NC} once, then reload your shell.

${BOLD}WORKTREE NAMING${NC}
  Branches with slashes are sanitized:  feature/auth → feature-auth
  Full path example:
    Repo  : ~/projects/myapp        (branch: feature/auth)
    Path  : ~/projects/myapp/${worktree_rel}/myapp.feature-auth

${BOLD}EXAMPLES${NC}
  wt add feature/login         # New worktree, creates branch if needed
  wt add main                  # Worktree for existing branch 'main'
  wt co feature/login          # Navigate to that worktree
  wt ls                        # Pretty-list all worktrees
  wt rm                        # Remove worktree you are currently in
  wt rm feature/login          # Remove a specific worktree
  wt mv feature/login auth-v2  # Rename a worktree
  wt prune                     # Clean up stale git metadata

EOF
}

# ── Entrypoint ────────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    add)              cmd_add "$@" ;;
    rm|remove)        cmd_remove "$@" ;;
    prune)            cmd_prune "$@" ;;
    ls|list)          cmd_list "$@" ;;
    mv|move)          cmd_move "$@" ;;
    co|checkout)      cmd_checkout "$@" ;;
    install)          cmd_install "$@" ;;
    help|-h|--help)   cmd_help ;;
    version|--version) echo "wt 1.0.0" ;;
    *)
      error "Unknown command: '${cmd}'"
      echo ""
      cmd_help
      exit 1
      ;;
  esac
}

main "$@"
