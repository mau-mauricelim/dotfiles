#!/usr/bin/env bash
# wt — Minimal Git Worktree Manager
set -euo pipefail

WT_VERSION="1.0.0"
WT_DIR=".worktree"

# ── Colors ────────────────────────────────────────────────────────────────────
# Do NOT use -t 1 — this script runs inside $() capture from the shell wrapper,
# so stdout is never a tty.  Instead honour NO_COLOR / TERM conventions.
RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; DIM=''; NC=''

_setup_colors() {
  # https://no-color.org
  [[ "${NO_COLOR:-}" != "" ]] && return
  # dumb terminal
  [[ "${TERM:-}" == "dumb" ]] && return
  # Need *some* terminal hint (TERM is inherited through $() captures)
  [[ -z "${TERM:-}" ]] && return

  RED=$'\033[0;31m'
  GREEN=$'\033[0;32m'
  YELLOW=$'\033[1;33m'
  BLUE=$'\033[0;34m'
  CYAN=$'\033[0;36m'
  BOLD=$'\033[1m'
  DIM=$'\033[2m'
  NC=$'\033[0m'
}
_setup_colors

# ── Helpers ───────────────────────────────────────────────────────────────────

die()     { printf '%berror:%b %s\n' "$RED" "$NC" "$*" >&2; exit 1; }
info()    { printf '%b→%b %s\n'     "$CYAN" "$NC" "$*"; }
success() { printf '%b✓%b %s\n'     "$GREEN" "$NC" "$*"; }
warn()    { printf '%b⚠%b %s\n'     "$YELLOW" "$NC" "$*"; }

# Pad a plain string to N chars, then wrap with color codes.
# This avoids ANSI bytes corrupting printf field widths.
_cpad() {
  # _cpad <color> <reset> <width> <string>
  local color="$1" reset="$2" width="$3" str="$4"
  local truncated="${str:0:$width}"
  local padded
  padded=$(printf "%-${width}s" "$truncated")
  printf '%b%s%b' "$color" "$padded" "$reset"
}

# Sanitize a branch name into a safe directory component.
# feature/my-thing  →  feature-my-thing
# fix/bug@1.0       →  fix-bug-1.0
sanitize_branch() {
  printf '%s' "$1" \
    | sed 's|/|-|g' \
    | sed 's|[^a-zA-Z0-9._-]|-|g' \
    | sed 's|^-\+||; s|-\+$||' \
    | sed 's|-\{2,\}|-|g'
}

# Derive a short repo name (origin remote → dirname → fallback).
repo_name() {
  local name
  name=$(git remote get-url origin 2>/dev/null \
    | sed 's|\.git$||; s|/$||; s|.*[/:]||') || true
  if [[ -z "$name" ]]; then
    name=$(basename "$(get_main_worktree)")
  fi
  printf '%s' "$name"
}

require_git() {
  git rev-parse --git-dir &>/dev/null || die "not inside a git repository"
}

# First entry in 'git worktree list' is always the main (non-linked) worktree.
get_main_worktree() {
  git worktree list --porcelain \
    | awk '/^worktree /{print substr($0,10); exit}'
}

# Return the top-level path of the worktree we are currently inside,
# or empty string when we are in the main worktree.
get_current_worktree() {
  local top
  top=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  local main
  main=$(get_main_worktree)
  [[ "$top" != "$main" ]] && printf '%s' "$top"
  return 0   # prevent set -e firing when top==main ([[ ]] exits 1)
}

# Given a worktree path, return its branch short name.
get_worktree_branch() {
  git worktree list --porcelain \
    | awk -v p="$1" '
        /^worktree / { cur = substr($0,10) }
        /^branch /   && cur == p { print substr($0,8); exit }
      ' \
    | sed 's|refs/heads/||'
}

# Resolve a user-supplied name to an absolute worktree path.
# Accepts:  bare name (feature1), sanitized name, or repo.name form.
resolve_wt_path() {
  local name="$1"
  local main repo san wt_path

  main=$(get_main_worktree)
  repo=$(repo_name)
  san=$(sanitize_branch "$name")

  # Try canonical form first
  wt_path="$main/$WT_DIR/${repo}.${san}"
  [[ -d "$wt_path" ]] && { printf '%s' "$wt_path"; return 0; }

  # Try raw sanitized name
  wt_path="$main/$WT_DIR/$san"
  [[ -d "$wt_path" ]] && { printf '%s' "$wt_path"; return 0; }

  # Try literal name
  wt_path="$main/$WT_DIR/$name"
  [[ -d "$wt_path" ]] && { printf '%s' "$wt_path"; return 0; }

  return 1
}

# Ensure the .worktree dir is listed in .git/info/exclude.
ensure_excluded() {
  local main exclude_file
  main=$(get_main_worktree)
  exclude_file="$main/.git/info/exclude"
  [[ -f "$exclude_file" ]] || return 0
  if ! grep -qxF "/$WT_DIR" "$exclude_file" 2>/dev/null; then
    printf '/%s\n' "$WT_DIR" >> "$exclude_file"
    info "added /$WT_DIR to .git/info/exclude"
  fi
}

# Emit a special cd directive that the shell wrapper intercepts.
emit_cd() { printf '__WT_CD__:%s\n' "$1"; }

# ── Commands ──────────────────────────────────────────────────────────────────

# wt init
# Prints a POSIX-compatible shell function definition; meant to be eval'd.
# Works in both bash and zsh.
cmd_init() {
  cat <<'SHELL_FUNC'
wt() {
  local _out _ret _cd

  # Capture stdout; stderr flows directly to terminal so git progress etc. show.
  _out=$(command wt "$@" 2>/dev/null)
  _ret=$?

  # Also run again to get stderr visible (errors), filtering cd directives.
  # We separate concerns: cd directive on stdout, human output on stderr path.
  # Simpler: just re-run? No — instead capture merged, strip directive lines.
  # Actually: capture stdout only (nuke prompt uses /dev/tty directly).
  _out=$(command wt "$@")
  _ret=$?

  # Extract an optional cd directive.
  _cd=$(printf '%s\n' "$_out" | grep '^__WT_CD__:' | tail -1 | sed 's/^__WT_CD__://')

  # Print everything except the hidden directive.
  printf '%s\n' "$_out" | grep -v '^__WT_CD__:'

  if [ -n "$_cd" ] && [ -d "$_cd" ]; then
    cd "$_cd" || return 1
  fi

  return $_ret
}
SHELL_FUNC
}

# wt add <branch>
cmd_add() {
  local branch="${1:-}"
  [[ -z "$branch" ]] && die "usage: wt add <branch>"

  require_git
  local main repo san wt_name wt_path
  main=$(get_main_worktree)
  repo=$(repo_name)
  san=$(sanitize_branch "$branch")
  wt_name="${repo}.${san}"
  wt_path="$main/$WT_DIR/$wt_name"

  # Idempotent: already exists → just cd there.
  if [[ -d "$wt_path" ]]; then
    warn "worktree already exists: ${BOLD}${wt_name}${NC}"
    emit_cd "$wt_path"
    return 0
  fi

  mkdir -p "$main/$WT_DIR"
  ensure_excluded

  info "creating worktree ${BOLD}${wt_name}${NC}  (branch: ${BOLD}${branch}${NC})"

  if git -C "$main" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
    git -C "$main" worktree add "$wt_path" "$branch"
  else
    info "branch ${BOLD}${branch}${NC} not found locally — creating it"
    git -C "$main" worktree add -b "$branch" "$wt_path"
  fi

  success "ready at ${BOLD}${wt_path}${NC}"
  emit_cd "$wt_path"
}

# wt rm [-f] [branch]
cmd_rm() {
  local force=0 target=""
  for arg in "$@"; do
    case "$arg" in
      -f|--force) force=1 ;;
      *)          target="$arg" ;;
    esac
  done

  require_git
  local main wt_path
  main=$(get_main_worktree)

  if [[ -z "$target" ]]; then
    wt_path=$(get_current_worktree)
    [[ -z "$wt_path" ]] \
      && die "not inside a managed worktree — specify a name: wt rm <branch>"
  else
    wt_path=$(resolve_wt_path "$target") \
      || die "worktree not found: $target"
  fi

  local was_here=0
  local cur
  cur=$(get_current_worktree)
  [[ "$cur" == "$wt_path" ]] && was_here=1

  local branch
  branch=$(get_worktree_branch "$wt_path")
  info "removing ${BOLD}$(basename "$wt_path")${NC}  (branch: ${branch:-(detached)})"

  local git_args=()
  [[ $force -eq 1 ]] && git_args+=(--force)
  git -C "$main" worktree remove "${git_args[@]}" "$wt_path"
  success "worktree removed"

  [[ $was_here -eq 1 ]] && emit_cd "$main"
}

# wt prune
cmd_prune() {
  require_git
  info "pruning stale worktree references"
  git worktree prune --verbose
  success "done"
}

# wt nuke [-f]
cmd_nuke() {
  local force=0
  for arg in "$@"; do
    [[ "$arg" == "-f" || "$arg" == "--force" ]] && force=1
  done

  require_git
  local main
  main=$(get_main_worktree)

  # Collect all non-main worktrees + their branches up-front.
  local -a paths=()
  local -a branches=()
  local _path="" _branch=""

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)  _path="${line#worktree }" ;;
      "branch "*)    _branch="${line#branch refs/heads/}" ;;
      "")
        if [[ -n "$_path" && "$_path" != "$main" ]]; then
          paths+=("$_path")
          branches+=("${_branch:-}")
        fi
        _path=""; _branch=""
        ;;
    esac
  done < <(git worktree list --porcelain; printf '\n')

  if [[ ${#paths[@]} -eq 0 ]]; then
    info "no linked worktrees to remove"
    return 0
  fi

  # ── Print the list — goes to normal stdout (captured by shell wrapper) ──
  printf '\n%bWorktrees to be nuked:%b\n' "$BOLD" "$NC"
  for p in "${paths[@]}"; do
    printf '  %b✗%b %s  %b%s%b\n' "$RED" "$NC" "$(basename "$p")" "$DIM" "$p" "$NC"
  done
  printf '\n'

  if [[ $force -eq 0 ]]; then
    # Write prompt directly to /dev/tty so it bypasses $() capture.
    printf '%bnuke all worktrees and their branches?%b [y/N] ' "$YELLOW" "$NC" > /dev/tty
    local confirm
    read -r confirm < /dev/tty
    if [[ "$confirm" != "y" && "$confirm" != "Y" ]]; then
      info "aborted"
      return 0
    fi
  fi

  local cur was_in_wt=0
  cur=$(get_current_worktree)
  [[ -n "$cur" ]] && was_in_wt=1

  local i
  for i in "${!paths[@]}"; do
    local p="${paths[$i]}"
    local b="${branches[$i]:-}"
    info "removing ${BOLD}$(basename "$p")${NC}"
    git -C "$main" worktree remove --force "$p" 2>/dev/null || true
    if [[ -n "$b" ]]; then
      if git -C "$main" branch -D "$b" 2>/dev/null; then
        success "deleted branch ${BOLD}${b}${NC}"
      else
        warn "could not delete branch $b (may not exist locally)"
      fi
    fi
  done

  git -C "$main" worktree prune 2>/dev/null || true
  success "all worktrees nuked"

  [[ $was_in_wt -eq 1 ]] && emit_cd "$main"
}

# wt ls
cmd_ls() {
  require_git

  local cur_top main_top
  cur_top=$(git rev-parse --show-toplevel 2>/dev/null || printf '')
  main_top=$(get_main_worktree)

  # ── First pass: collect all entries to compute column widths ────────────
  local -a all_paths=() all_heads=() all_branches=()
  local _path="" _head="" _branch="" _detached=0

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)  _path="${line#worktree }"; _head=""; _branch=""; _detached=0 ;;
      "HEAD "*)      _head="${line#HEAD }" ;;
      "branch "*)    _branch="${line#branch refs/heads/}" ;;
      "detached")    _detached=1 ;;
      "bare")        _branch="(bare)" ;;
      "")
        if [[ -n "$_path" ]]; then
          all_paths+=("$_path")
          all_heads+=("${_head:0:7}")
          if [[ $_detached -eq 1 ]]; then
            all_branches+=("HEAD (detached)")
          else
            all_branches+=("${_branch:-}")
          fi
        fi
        _path=""; _head=""; _branch=""; _detached=0
        ;;
    esac
  done < <(git worktree list --porcelain; printf '\n')

  # Compute max visible label length (cap at 50 chars)
  local max_label=10
  for p in "${all_paths[@]}"; do
    local lbl
    lbl=$(basename "$p")
    local len=${#lbl}
    [[ $len -gt 50 ]] && len=50
    [[ $len -gt $max_label ]] && max_label=$len
  done
  # Add 2 for the [main] badge if present; round up
  local col_width=$(( max_label + 2 ))

  # ── Second pass: render ─────────────────────────────────────────────────
  printf '\n%bWorktrees%b\n\n' "$BOLD" "$NC"

  local i
  for i in "${!all_paths[@]}"; do
    local p="${all_paths[$i]}"
    local head="${all_heads[$i]}"
    local branch="${all_branches[$i]}"
    local label
    label=$(basename "$p")

    local is_cur=0 is_main=0
    [[ "$p" == "$cur_top" ]]  && is_cur=1
    [[ "$p" == "$main_top" ]] && is_main=1

    # Truncate long label with ellipsis
    local display_label="$label"
    if [[ ${#label} -gt 50 ]]; then
      display_label="${label:0:47}..."
    fi

    # Marker + colors
    local marker color branch_color
    if [[ $is_cur -eq 1 ]]; then
      marker="${GREEN}▶${NC}"
      color="$BOLD"
      branch_color="$CYAN"
    else
      marker="${DIM}◦${NC}"
      color="$DIM"
      branch_color="$BLUE"
    fi

    # Build the [main] badge (part of the padded label column)
    local badge=""
    [[ $is_main -eq 1 ]] && badge=" ${DIM}[main]${NC}"

    # Pad the plain label to col_width BEFORE adding any color codes.
    local padded_label
    padded_label=$(printf "%-${col_width}s" "$display_label")

    printf '  %b%b %b%s%b%s  %b%s%b  %b%s%b\n' \
      "$marker" "$NC" \
      "$color"  "$padded_label" "$NC" \
      "$badge" \
      "$DIM"   "$head"   "$NC" \
      "$branch_color" "${branch:-(detached)}" "$NC"
  done

  printf '\n'
}

# wt mv <from> <to>
cmd_mv() {
  local from="${1:-}" to="${2:-}"
  [[ -z "$from" || -z "$to" ]] && die "usage: wt mv <from> <to>"

  require_git
  local main repo to_san to_path from_path
  main=$(get_main_worktree)
  repo=$(repo_name)

  from_path=$(resolve_wt_path "$from") \
    || die "source worktree not found: $from"

  to_san=$(sanitize_branch "$to")
  to_path="$main/$WT_DIR/${repo}.${to_san}"

  local was_here=0
  local cur
  cur=$(get_current_worktree)
  [[ "$cur" == "$from_path" ]] && was_here=1

  info "moving ${BOLD}$(basename "$from_path")${NC} → ${BOLD}$(basename "$to_path")${NC}"
  git -C "$main" worktree move "$from_path" "$to_path"
  success "moved to $to_path"

  [[ $was_here -eq 1 ]] && emit_cd "$to_path"
}

# wt co <branch>
cmd_co() {
  local target="${1:-}"
  [[ -z "$target" ]] && die "usage: wt co <branch>"

  require_git
  local wt_path
  wt_path=$(resolve_wt_path "$target") \
    || die "worktree not found: $target  (use 'wt add $target' to create it)"

  emit_cd "$wt_path"
}

# wt help
cmd_help() {
  printf '\n'
  printf '%bwt%b — Git Worktree Manager %b v%s%b\n\n' "$BOLD" "$NC" "$DIM" "$WT_VERSION" "$NC"
  printf '%bUSAGE%b\n'    "$BOLD" "$NC"
  printf '  wt <command> [options]\n\n'
  printf '%bCOMMANDS%b\n' "$BOLD" "$NC"
  printf '  %binit%b                 Output shell function for auto-cd support\n'  "$CYAN" "$NC"
  printf '  %badd%b  <branch>        Add a new worktree for <branch>\n'             "$CYAN" "$NC"
  printf '  %brm%b   [-f] [branch]   Remove current or named worktree\n'            "$CYAN" "$NC"
  printf '  %bco%b   <branch>        Switch into a worktree (cd)\n'                 "$CYAN" "$NC"
  printf '  %bls%b                   List all worktrees\n'                           "$CYAN" "$NC"
  printf '  %bmv%b   <from> <to>     Move / rename a worktree\n'                    "$CYAN" "$NC"
  printf '  %bprune%b                Prune stale worktree references\n'              "$CYAN" "$NC"
  printf '  %bnuke%b  [-f]           Remove ALL worktrees and their branches\n\n'   "$CYAN" "$NC"
  printf '%bWORKTREE LOCATION%b\n'  "$BOLD" "$NC"
  printf '  <repo-root>/.worktree/<repo-name>.<sanitized-branch>\n'
  printf '  e.g.  feature/login  →  myrepo.feature-login\n\n'
  printf '%bSETUP%b\n'   "$BOLD" "$NC"
  printf '  Add to ~/.bashrc or ~/.zshrc:\n\n'
  printf '    %beval "$(wt init)"%b\n\n' "$DIM" "$NC"
  printf '%bEXAMPLES%b\n' "$BOLD" "$NC"
  printf '  %bwt add feature/login%b   Create worktree for feature/login\n' "$DIM" "$NC"
  printf '  %bwt co  feature/login%b   Switch into that worktree\n'         "$DIM" "$NC"
  printf '  %bwt ls%b                  Show all worktrees\n'                "$DIM" "$NC"
  printf '  %bwt rm%b                  Remove current worktree & cd back\n' "$DIM" "$NC"
  printf '  %bwt rm feature/login%b    Remove a specific worktree\n'        "$DIM" "$NC"
  printf '  %bwt rm -f%b               Force-remove current worktree\n'     "$DIM" "$NC"
  printf '  %bwt mv old new%b          Rename a worktree\n'                 "$DIM" "$NC"
  printf '  %bwt nuke -f%b             Nuke everything (no prompt)\n'       "$DIM" "$NC"
  printf '  %bwt prune%b               Clean up stale references\n'         "$DIM" "$NC"
  printf '\n'
}

# ── Entry point ───────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)                cmd_init            ;;
    add)                 cmd_add    "$@"     ;;
    rm|remove)           cmd_rm     "$@"     ;;
    co|checkout)         cmd_co     "$@"     ;;
    ls|list)             cmd_ls              ;;
    mv|move)             cmd_mv     "$@"     ;;
    prune)               cmd_prune           ;;
    nuke)                cmd_nuke   "$@"     ;;
    help|-h|--help)      cmd_help            ;;
    version|-V|--version) printf 'wt %s\n' "$WT_VERSION" ;;
    *) die "unknown command: '$cmd'  (run 'wt help')" ;;
  esac
}

main "$@"
