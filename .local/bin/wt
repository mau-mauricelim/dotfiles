#!/usr/bin/env bash
# wt — Minimal Git Worktree Manager

set -euo pipefail

WT_VERSION="1.0.0"
WT_DIR=".worktree"

# ── Colors ────────────────────────────────────────────────────────────────────
if [[ -t 1 ]]; then
  RED='\033[0;31m'
  GREEN='\033[0;32m'
  YELLOW='\033[1;33m'
  BLUE='\033[0;34m'
  CYAN='\033[0;36m'
  BOLD='\033[1m'
  DIM='\033[2m'
  NC='\033[0m'
else
  RED=''; GREEN=''; YELLOW=''; BLUE=''; CYAN=''; BOLD=''; DIM=''; NC=''
fi

# ── Helpers ───────────────────────────────────────────────────────────────────

die()     { echo -e "${RED}error:${NC} $*" >&2; exit 1; }
info()    { echo -e "${CYAN}→${NC} $*"; }
success() { echo -e "${GREEN}✓${NC} $*"; }
warn()    { echo -e "${YELLOW}⚠${NC} $*"; }

# Sanitize a branch name into a safe directory component.
# feature/my-thing  →  feature-my-thing
# fix/bug@1.0       →  fix-bug-1.0
sanitize_branch() {
  printf '%s' "$1" \
    | sed 's|/|-|g' \
    | sed 's|[^a-zA-Z0-9._-]|-|g' \
    | sed 's|^-\+||; s|-\+$||' \
    | sed 's|-\{2,\}|-|g'
}

# Derive a short repo name (origin remote → dirname → fallback).
repo_name() {
  local name
  name=$(git remote get-url origin 2>/dev/null \
    | sed 's|\.git$||; s|/$||; s|.*[/:]||') || true
  if [[ -z "$name" ]]; then
    name=$(basename "$(get_main_worktree)")
  fi
  printf '%s' "$name"
}

require_git() {
  git rev-parse --git-dir &>/dev/null || die "not inside a git repository"
}

# First entry in 'git worktree list' is always the main (non-linked) worktree.
get_main_worktree() {
  git worktree list --porcelain \
    | awk '/^worktree /{print substr($0,10); exit}'
}

# Return the top-level path of the worktree we are currently inside,
# or empty string when we are in the main worktree.
get_current_worktree() {
  local top
  top=$(git rev-parse --show-toplevel 2>/dev/null) || return 0
  local main
  main=$(get_main_worktree)
  if [[ "$top" != "$main" ]]; then
    printf '%s' "$top"
  fi
}

# Given a worktree path, return its branch short name.
get_worktree_branch() {
  git worktree list --porcelain \
    | awk -v p="$1" '
        /^worktree / { cur = substr($0,10) }
        /^branch /   && cur == p { print substr($0,8); exit }
      ' \
    | sed 's|refs/heads/||'
}

# Resolve a user-supplied name to an absolute worktree path.
# Accepts:  bare name (feature1), sanitized name, or repo.name form.
resolve_wt_path() {
  local name="$1"
  local main repo san wt_path

  main=$(get_main_worktree)
  repo=$(repo_name)
  san=$(sanitize_branch "$name")

  # Try canonical form first
  wt_path="$main/$WT_DIR/${repo}.${san}"
  [[ -d "$wt_path" ]] && { printf '%s' "$wt_path"; return; }

  # Try raw sanitized name
  wt_path="$main/$WT_DIR/$san"
  [[ -d "$wt_path" ]] && { printf '%s' "$wt_path"; return; }

  # Try literal name
  wt_path="$main/$WT_DIR/$name"
  [[ -d "$wt_path" ]] && { printf '%s' "$wt_path"; return; }

  # Nothing found
  return 1
}

# Ensure the .worktree dir is listed in .git/info/exclude.
ensure_excluded() {
  local main exclude_file
  main=$(get_main_worktree)
  exclude_file="$main/.git/info/exclude"
  [[ -f "$exclude_file" ]] || return 0
  if ! grep -qxF "/$WT_DIR" "$exclude_file" 2>/dev/null; then
    printf '/%s\n' "$WT_DIR" >> "$exclude_file"
    info "added /$WT_DIR to .git/info/exclude"
  fi
}

# Emit a special cd directive that the shell wrapper intercepts.
emit_cd() { printf '__WT_CD__:%s\n' "$1"; }

# ── Commands ──────────────────────────────────────────────────────────────────

# wt init
# Prints a POSIX-compatible shell function definition; meant to be eval'd.
# Works in both bash and zsh.
cmd_init() {
  cat <<'SHELL_FUNC'
wt() {
  # Capture all output (stdout + stderr merged so colors still appear).
  local _out _ret _cd
  _out=$(command wt "$@" 2>&1)
  _ret=$?

  # Extract an optional cd directive from the output.
  _cd=$(printf '%s\n' "$_out" | grep '^__WT_CD__:' | tail -1 | sed 's/^__WT_CD__://')

  # Print everything except the hidden directive.
  printf '%s\n' "$_out" | grep -v '^__WT_CD__:'

  # Perform the cd in the current shell process.
  if [ -n "$_cd" ] && [ -d "$_cd" ]; then
    cd "$_cd" || return 1
  fi

  return $_ret
}
SHELL_FUNC
}

# wt add <branch>
cmd_add() {
  local branch="${1:-}"
  [[ -z "$branch" ]] && die "usage: wt add <branch>"

  require_git
  local main repo san wt_name wt_path
  main=$(get_main_worktree)
  repo=$(repo_name)
  san=$(sanitize_branch "$branch")
  wt_name="${repo}.${san}"
  wt_path="$main/$WT_DIR/$wt_name"

  # Idempotent: already exists → just cd there.
  if [[ -d "$wt_path" ]]; then
    warn "worktree already exists: ${BOLD}$wt_name${NC}"
    emit_cd "$wt_path"
    return 0
  fi

  mkdir -p "$main/$WT_DIR"
  ensure_excluded

  info "creating worktree ${BOLD}$wt_name${NC}  (branch: ${BOLD}$branch${NC})"

  if git -C "$main" show-ref --verify --quiet "refs/heads/$branch" 2>/dev/null; then
    git -C "$main" worktree add "$wt_path" "$branch"
  else
    info "branch ${BOLD}$branch${NC} not found locally — creating it"
    git -C "$main" worktree add -b "$branch" "$wt_path"
  fi

  success "ready at ${BOLD}$wt_path${NC}"
  emit_cd "$wt_path"
}

# wt rm [-f] [branch]
cmd_rm() {
  local force=0 target=""
  for arg in "$@"; do
    case "$arg" in
      -f|--force) force=1 ;;
      *)          target="$arg" ;;
    esac
  done

  require_git
  local main wt_path
  main=$(get_main_worktree)

  if [[ -z "$target" ]]; then
    wt_path=$(get_current_worktree)
    [[ -z "$wt_path" ]] \
      && die "not inside a managed worktree — specify a name: wt rm <branch>"
  else
    wt_path=$(resolve_wt_path "$target") \
      || die "worktree not found: $target"
  fi

  # Will we need to escape the worktree?
  local was_here=0
  local cur
  cur=$(get_current_worktree)
  [[ "$cur" == "$wt_path" ]] && was_here=1

  local branch
  branch=$(get_worktree_branch "$wt_path")
  info "removing ${BOLD}$(basename "$wt_path")${NC}  (branch: ${branch:-(detached)})"

  local git_args=()
  [[ $force -eq 1 ]] && git_args+=(--force)
  git -C "$main" worktree remove "${git_args[@]}" "$wt_path"
  success "worktree removed"

  [[ $was_here -eq 1 ]] && emit_cd "$main"
}

# wt prune
cmd_prune() {
  require_git
  info "pruning stale worktree references"
  git worktree prune --verbose
  success "done"
}

# wt nuke [-f]
cmd_nuke() {
  local force=0
  for arg in "$@"; do
    [[ "$arg" == "-f" || "$arg" == "--force" ]] && force=1
  done

  require_git
  local main
  main=$(get_main_worktree)

  # Collect all non-main worktrees + their branches up-front.
  local -a paths=()
  local -a branches=()
  local path branch

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        path="${line#worktree }"
        ;;
      "branch "*)
        branch="${line#branch refs/heads/}"
        ;;
      "")
        if [[ -n "${path:-}" && "$path" != "$main" ]]; then
          paths+=("$path")
          branches+=("${branch:-}")
        fi
        path=""; branch=""
        ;;
    esac
  done < <(git worktree list --porcelain; echo "")

  if [[ ${#paths[@]} -eq 0 ]]; then
    info "no linked worktrees to remove"
    return 0
  fi

  echo -e "\n${BOLD}Worktrees to be nuked:${NC}"
  for p in "${paths[@]}"; do
    echo -e "  ${RED}✗${NC} $(basename "$p")  ${DIM}$p${NC}"
  done
  echo ""

  if [[ $force -eq 0 ]]; then
    printf '%b' "${YELLOW}nuke all worktrees and their branches?${NC} [y/N] "
    local confirm
    read -r confirm
    [[ "$confirm" != "y" && "$confirm" != "Y" ]] && { info "aborted"; return 0; }
  fi

  local cur was_in_wt=0
  cur=$(get_current_worktree)
  [[ -n "$cur" ]] && was_in_wt=1

  for i in "${!paths[@]}"; do
    local p="${paths[$i]}"
    local b="${branches[$i]:-}"
    info "removing ${BOLD}$(basename "$p")${NC}"
    git -C "$main" worktree remove --force "$p" 2>/dev/null || true
    if [[ -n "$b" ]]; then
      if git -C "$main" branch -D "$b" 2>/dev/null; then
        success "deleted branch ${BOLD}$b${NC}"
      else
        warn "could not delete branch $b (may not exist)"
      fi
    fi
  done

  git -C "$main" worktree prune 2>/dev/null || true
  success "all worktrees nuked"

  [[ $was_in_wt -eq 1 ]] && emit_cd "$main"
}

# wt ls
cmd_ls() {
  require_git

  local cur_top main_top
  cur_top=$(git rev-parse --show-toplevel 2>/dev/null || echo "")
  main_top=$(get_main_worktree)

  echo -e "\n${BOLD}Worktrees${NC}\n"

  local path branch head
  path=""; branch=""; head=""

  _flush_entry() {
    [[ -z "$path" ]] && return
    local label is_cur is_main marker color branch_color

    label=$(basename "$path")
    is_cur=$([[ "$path" == "$cur_top" ]] && echo 1 || echo 0)
    is_main=$([[ "$path" == "$main_top" ]] && echo 1 || echo 0)

    if [[ $is_cur -eq 1 ]]; then
      marker="${GREEN}▶${NC}"
      color="$BOLD"
      branch_color="$CYAN"
    else
      marker="${DIM}◦${NC}"
      color="$DIM"
      branch_color="$BLUE"
    fi

    local tag=""
    [[ $is_main -eq 1 ]] && tag=" ${DIM}[main]${NC}"

    printf "  %b %b%-40s%b%b  %b%s%b  %b%s%b\n" \
      "$marker" "$color" "$label" "$NC" "$tag" \
      "$DIM" "${head:0:7}" "$NC" \
      "$branch_color" "${branch:-(detached)}" "$NC"
  }

  while IFS= read -r line; do
    case "$line" in
      "worktree "*)
        _flush_entry
        path="${line#worktree }"
        branch=""; head=""
        ;;
      "HEAD "*)    head="${line#HEAD }" ;;
      "branch "*)  branch="${line#branch refs/heads/}" ;;
      "detached")  branch="HEAD (detached)" ;;
      "bare")      branch="(bare)" ;;
      "")
        _flush_entry
        path=""; branch=""; head=""
        ;;
    esac
  done < <(git worktree list --porcelain; echo "")

  echo ""
}

# wt mv <from> <to>
cmd_mv() {
  local from="${1:-}" to="${2:-}"
  [[ -z "$from" || -z "$to" ]] && die "usage: wt mv <from> <to>"

  require_git
  local main repo to_san to_path from_path
  main=$(get_main_worktree)
  repo=$(repo_name)

  from_path=$(resolve_wt_path "$from") \
    || die "source worktree not found: $from"

  to_san=$(sanitize_branch "$to")
  to_path="$main/$WT_DIR/${repo}.${to_san}"

  local was_here=0
  local cur
  cur=$(get_current_worktree)
  [[ "$cur" == "$from_path" ]] && was_here=1

  info "moving ${BOLD}$(basename "$from_path")${NC} → ${BOLD}$(basename "$to_path")${NC}"
  git -C "$main" worktree move "$from_path" "$to_path"
  success "moved to $to_path"

  [[ $was_here -eq 1 ]] && emit_cd "$to_path"
}

# wt co <branch>
cmd_co() {
  local target="${1:-}"
  [[ -z "$target" ]] && die "usage: wt co <branch>"

  require_git
  local wt_path
  wt_path=$(resolve_wt_path "$target") \
    || die "worktree not found: $target  (use 'wt add $target' to create it)"

  emit_cd "$wt_path"
}

# wt help
cmd_help() {
  cat <<EOF

$(printf '%b' "${BOLD}wt${NC} — Git Worktree Manager ${DIM}v${WT_VERSION}${NC}")

$(printf '%b' "${BOLD}USAGE${NC}")
  wt <command> [options]

$(printf '%b' "${BOLD}COMMANDS${NC}")
  $(printf '%b' "${CYAN}init${NC}")                Output shell function for auto-cd support
  $(printf '%b' "${CYAN}add${NC}") <branch>        Add a new worktree for <branch>
  $(printf '%b' "${CYAN}rm${NC}")  [-f] [branch]   Remove current or named worktree
  $(printf '%b' "${CYAN}co${NC}")  <branch>        Switch into a worktree (cd)
  $(printf '%b' "${CYAN}ls${NC}")                  List all worktrees
  $(printf '%b' "${CYAN}mv${NC}")  <from> <to>     Move / rename a worktree
  $(printf '%b' "${CYAN}prune${NC}")               Prune stale worktree references
  $(printf '%b' "${CYAN}nuke${NC}") [-f]           Remove ALL worktrees and their branches

$(printf '%b' "${BOLD}WORKTREE LOCATION${NC}")
  <repo-root>/.worktree/<repo-name>.<sanitized-branch>

  e.g.  feature/login  →  myrepo.feature-login

$(printf '%b' "${BOLD}SETUP${NC}")
  Add to your ~/.bashrc or ~/.zshrc:

    $(printf '%b' "${DIM}eval \"\$(wt init)\"${NC}")

  This installs a shell wrapper that enables automatic directory changes.

$(printf '%b' "${BOLD}EXAMPLES${NC}")
  $(printf '%b' "${DIM}wt add feature/login${NC}")       Create worktree for feature/login
  $(printf '%b' "${DIM}wt co feature/login${NC}")        Switch into that worktree
  $(printf '%b' "${DIM}wt ls${NC}")                      Show all worktrees
  $(printf '%b' "${DIM}wt rm${NC}")                      Remove current worktree & cd back
  $(printf '%b' "${DIM}wt rm feature/login${NC}")        Remove a specific worktree
  $(printf '%b' "${DIM}wt rm -f${NC}")                   Force-remove current worktree
  $(printf '%b' "${DIM}wt mv old-name new-name${NC}")    Rename a worktree
  $(printf '%b' "${DIM}wt nuke -f${NC}")                 Nuke everything (no prompt)
  $(printf '%b' "${DIM}wt prune${NC}")                   Clean up stale references

EOF
}

# ── Entry point ───────────────────────────────────────────────────────────────

main() {
  local cmd="${1:-help}"
  shift || true

  case "$cmd" in
    init)              cmd_init            ;;
    add)               cmd_add    "$@"     ;;
    rm|remove)         cmd_rm     "$@"     ;;
    co|checkout)       cmd_co     "$@"     ;;
    ls|list)           cmd_ls              ;;
    mv|move)           cmd_mv     "$@"     ;;
    prune)             cmd_prune           ;;
    nuke)              cmd_nuke   "$@"     ;;
    help|-h|--help)    cmd_help            ;;
    version|-V|--version) echo "wt $WT_VERSION" ;;
    *) die "unknown command: '$cmd'  (run 'wt help')" ;;
  esac
}

main "$@"
