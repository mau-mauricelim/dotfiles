#!/usr/bin/env bash

set -euo pipefail

TEST_DIR="/tmp/wt-test-$$"
mkdir -p "$TEST_DIR"; cd "$TEST_DIR"
git init main-repo; cd main-repo

eval "$(wt init)"

wt ignore
wt add feature1
[[ "$(basename "$(pwd)")" == "feature1" ]] && echo "✅ auto-cd works" || echo "FAIL"

echo "🎉 Test passed — run 'rm -rf $TEST_DIR' to clean up"
