#!/usr/bin/env bash
set -euo pipefail

TEST_DIR="/tmp/wt-test-$$"
mkdir -p "$TEST_DIR"
cd "$TEST_DIR"
git init main-repo
cd main-repo
echo ".worktree/" >> .gitignore
git add .gitignore
git commit -m "init"

echo "🧪 Running wt tests..."

# Basic flow
wt add feature1
[[ "$(basename "$(pwd)")" == "feature1" ]] || { echo "FAIL: auto-cd"; exit 1; }

# Successive add (no nesting)
cd ..
wt add feature2
[[ "$(pwd)" == "$TEST_DIR/main-repo/.worktree/feature2" ]] || { echo "FAIL: nesting"; exit 1; }

# Sanitization tests
wt add "feature/user dashboard"
[[ -d ".worktree/feature-user_dashboard" ]] || { echo "FAIL: sanitization"; exit 1; }
echo "✅ Sanitization: feature/user dashboard → feature-user_dashboard"

wt co feature/user-dashboard   # should work via sanitization
[[ "$(basename "$(pwd)")" == "feature-user_dashboard" ]] || { echo "FAIL: co sanitized"; exit 1; }

# rm current
wt rm
[[ "$(pwd)" == "$TEST_DIR/main-repo" ]] || { echo "FAIL: rm current"; exit 1; }

# mv with sanitization
wt add "old name"
wt mv "old name" "new name"
[[ -d ".worktree/new_name" ]] || { echo "FAIL: mv"; exit 1; }

echo "🎉 ALL TESTS PASSED! (including sanitization and auto-cd)"
echo "Clean up: rm -rf $TEST_DIR"
