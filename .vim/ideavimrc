" +-----------------+
" | IdeaVim Plugins |
" +-----------------+
" Better join
set ideajoin

" Adds mapping for quickly commenting stuff out
set commentary

" Easy text exchange operator
set exchange
nmap gx <Plug>(Exchange)
xmap gx <Plug>(Exchange)
nmap gxc <Plug>(ExchangeClear)
nmap gxx <Plug>(ExchangeLine)

" Highlights the yanked region
set highlightedyank

" Extend and create a/i textobjects
set mini-ai

" Adds provides mappings to easily delete, change, and add surroundings in pairs
set surround
nmap sa ys
nmap sd ds
nmap sr cs
" Visual mode
xmap sa S

" +---------+
" | Options |
" +---------+
let mapleader = " "
let maplocalleader = " "

" UI / Display
set number relativenumber
set cursorline
set nowrap
set list
set listchars=tab:»\ ,trail:·,nbsp:␣
set scrolloff=10

" Search behavior
set ignorecase smartcase
set incsearch hlsearch

" Disable audible and visual bells
set noerrorbells visualbell
set t_vb=

" System & Formatting
set tabstop=4
set shiftwidth=4
set expandtab
set timeoutlen=300
set splitright splitbelow
set virtualedit=onemore

" +---------+
" | Keymaps |
" +---------+
" Don't use Ex mode, use Q for formatting
map Q gq
" Clear highlights on Esc
nnoremap <silent> <Esc> :nohlsearch<CR><Esc>

" Split navigation
nnoremap <C-h> <C-w><C-h>
nnoremap <C-l> <C-w><C-l>
nnoremap <C-j> <C-w><C-j>
nnoremap <C-k> <C-w><C-k>

" Center screen on navigation
nnoremap k kzz
vnoremap k kzz
nnoremap j jzz
vnoremap j jzz
nnoremap G Gzz
vnoremap G Gzz
nnoremap <C-End> Gzz
vnoremap <C-End> Gzz
nnoremap <Up> kzz
vnoremap <Up> kzz
nnoremap <Down> jzz
vnoremap <Down> jzz
nnoremap <C-u> <C-u>zz
vnoremap <C-u> <C-u>zz
nnoremap <C-d> <C-d>zz
vnoremap <C-d> <C-d>zz
nnoremap <PageUp> <C-u>zz
vnoremap <PageUp> <C-u>zz
nnoremap <PageDown> <C-d>zz
vnoremap <PageDown> <C-d>zz

" Saner n and N
nnoremap n nzzzv
nnoremap N Nzzzv

" Join line below cursor while maintaining position
nnoremap J mzJ`z

" Escape mappings
inoremap <C-c> <Esc>
inoremap kj <Esc>
vnoremap kj <Esc>
inoremap KJ <Esc>
vnoremap KJ <Esc>

" Select to end/start of line
nnoremap L v$h
vnoremap L $h
nnoremap H v^
vnoremap H ^

" Delete into black hole register
vnoremap D "_d
nnoremap dD "_dd
vnoremap C "_c
nnoremap cC "_cc

" Indenting remains in visual mode
vnoremap < <gv
vnoremap > >gv

" Insert tab space in normal mode
nnoremap <Tab> i<Tab><Esc>

" Sentence case word
nnoremap <Leader>gS guiwv~

" Split and move
nnoremap <Leader><Bar> :vsp<CR>
nnoremap <Leader>- :sp<CR>

" Text manipulation
nnoremap <silent> <Leader>; mzA;<Esc>`z
vnoremap <silent> <Leader>; mz<C-q>$A;<Esc>
nnoremap <Leader>ca ggdGi
nnoremap <Leader>da ggdG
nnoremap <silent> <Leader>ya :%y<CR>
nnoremap <silent> <Leader>va ggVG$

" Delete empty lines globally
nnoremap <Leader>le :g/^$/d<CR>

" Search and replace word under cursor
nnoremap <Leader>/r :%s/<C-r><C-w>//g<Left><Left>
nnoremap <Leader>/w /\<\><Left><Left>

" Search current without moving cursor
nnoremap * *N
vnoremap * *N
nnoremap # #n
vnoremap # #n

" Toggle alternate or last file
nnoremap <silent> <Leader>. :e#<CR>

" +-------------+
" | IDE Actions |
" +-------------+
" Save file
nnoremap <C-s> :action SaveAll<CR>
inoremap <C-s> <Esc>:action SaveAll<CR>
xnoremap <C-s> <Esc>:action SaveAll<CR>

" File searching (Replacing FZF)
nnoremap <Leader>sf :action GotoFile<CR>
vnoremap <Leader>sf <Esc>:action GotoFile<CR>
nnoremap <Leader><Leader> :action RecentFiles<CR>
vnoremap <Leader><Leader> <Esc>:action RecentFiles<CR>
nnoremap <Leader>sg :action FindInPath<CR>
vnoremap <Leader>sg <Esc>:action FindInPath<CR>
nnoremap <Leader>s. :action RecentFiles<CR>
nnoremap <Leader>sc :action Console.History<CR>
nnoremap <Leader>sk :action KeymapSettings<CR>

" GitGutter equivalent
nmap ]h :action VcsShowNextChangeMarker<CR>
nmap [h :action VcsShowPrevChangeMarker<CR>

" Buffers / Tabs
nnoremap ]b :action NextTab<CR>
nnoremap [b :action PreviousTab<CR>

" Quickfix list equivalent (Tool window)
nnoremap <Leader>lq :action ActivateProblemsViewToolWindow<CR>

" Formatting (Replacing custom shell/awk functions)
" Let the IDE handle trailing spaces and file formatting
nnoremap <silent> <Leader>fl :action ReformatCode<CR>
vnoremap <silent> <Leader>fl :action ReformatCode<CR>
nnoremap <silent> <Leader>jq :action ReformatCode<CR>

" Copy file path
nnoremap <silent> <Leader>cf :action CopyReference<CR>
nnoremap <silent> <Leader>cp :action CopyAbsolutePath<CR>
